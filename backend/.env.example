# ──────────────────────────────────────────
# CamToCode Backend — Environment Variables
# Copy this file to .env and fill in values
# ──────────────────────────────────────────

# Supabase project URL (from Project Settings > API)
SUPABASE_URL=https://your-project-id.supabase.co

# Supabase service_role key (NOT anon key — has full access)
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Supabase JWT secret (from Project Settings > API > JWT Settings)
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# Anthropic API key
ANTHROPIC_API_KEY=sk-ant-api03-...

# Frontend URL (Vercel domain — for CORS)
FRONTEND_URL=https://your-app.vercel.app

# Flask secret key (generate a random string)
SECRET_KEY=change-me-to-a-random-secret

# Port (Railway sets this automatically)
PORT=5000

# Optional: Tesseract binary path (needed on Windows dev; Linux uses system tesseract)
# TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe
