# ─────────────────────────────────────────────────
# CamToCode Frontend — Environment Variables
# Copy to .env.local and fill in values
# ─────────────────────────────────────────────────

# Supabase project URL (from Project Settings > API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co

# Supabase anon/public key
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Railway backend URL
NEXT_PUBLIC_BACKEND_URL=https://your-app.railway.app

# Public site URL (SEO, share links, sitemap) — use https://camtocode.com in production
NEXT_PUBLIC_SITE_URL=https://camtocode.com
